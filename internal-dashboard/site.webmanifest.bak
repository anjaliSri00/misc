{
    "name": "Internal Dashboard - Vendor Management System",
    "short_name": "Internal Dashboard",
    "description": "Comprehensive vendor management dashboard with advanced analytics and business intelligence",
    "start_url": "/internal-dashboard/",
    "display": "standalone",
    "theme_color": "#5650DE",
    "background_color": "#ffffff",
    "orientation": "portrait-primary",
    "scope": "/internal-dashboard/",
    "lang": "en-US",
    "dir": "ltr",
    "categories": [
        "business",
        "productivity",
        "utilities"
    ],
    "screenshots": [
        {
            "src": "data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 512 512'><rect width='512' height='512' fill='%235650DE'/><text x='256' y='280' font-size='200' text-anchor='middle' fill='white'>🏢</text></svg>",
            "sizes": "512x512",
            "type": "image/svg+xml",
            "form_factor": "wide",
            "label": "Dashboard Overview"
        }
    ],
    "icons": [
        {
            "src": "data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 192 192'><rect width='192' height='192' fill='%235650DE' rx='20'/><text x='96' y='130' font-size='80' text-anchor='middle' fill='white'>🏢</text></svg>",
            "sizes": "192x192",
            "type": "image/svg+xml",
            "purpose": "any maskable"
        },
        {
            "src": "data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 512 512'><rect width='512' height='512' fill='%235650DE' rx='50'/><text x='256' y='350' font-size='200' text-anchor='middle' fill='white'>🏢</text></svg>",
            "sizes": "512x512",
            "type": "image/svg+xml",
            "purpose": "any maskable"
        }
    ],
    "shortcuts": [
        {
            "name": "Vendor List",
            "short_name": "Vendors",
            "description": "View and manage all vendors",
            "url": "/internal-dashboard/dashboard.html#vendors",
            "icons": [
                {
                    "src": "data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 96 96'><text x='48' y='65' font-size='48' text-anchor='middle'>👥</text></svg>",
                    "sizes": "96x96",
                    "type": "image/svg+xml"
                }
            ]
        },
        {
            "name": "Analytics",
            "short_name": "Analytics",
            "description": "View business analytics and reports",
            "url": "/internal-dashboard/dashboard.html#analytics",
            "icons": [
                {
                    "src": "data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 96 96'><text x='48' y='65' font-size='48' text-anchor='middle'>📊</text></svg>",
                    "sizes": "96x96",
                    "type": "image/svg+xml"
                }
            ]
        }
    ],
    "prefer_related_applications": false,
    "edge_side_panel": {
        "preferred_width": 400
    },
    "launch_handler": {
        "client_mode": ["navigate-existing", "auto"]
    },
    "handle_links": "preferred",
    "display_override": ["window-controls-overlay", "standalone"],
    "protocol_handlers": [
        {
            "protocol": "web+dashboard",
            "url": "/internal-dashboard/?action=%s"
        }
    ]
} 